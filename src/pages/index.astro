---
import { Image } from "astro:assets";
import ProductCard from "@/components/ProductCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import heroImg from "@/assets/atelier-hero.jpg";
import { formatPrice, getProducts } from "@/data/products.js";

const products = await getProducts();
const featured = ["arvid-chair", "low-plinth-table", "tora-desk"]
  .map((slug) => products.find((product) => product.slug === slug))
  .filter(Boolean);
const solo = products.find((product) => product.slug === "monolith-bench");

if (!solo) {
  throw new Error("Missing required featured product: monolith-bench");
}
---

<BaseLayout
  title="Atelier Kō — Furniture, made by hand"
  description="A small catalogue of seating, tables and storage. Solid oak, ash and walnut, hand-built to order in Småland, Sweden."
  image={heroImg}
>
  <main id="main-content">
  <h1 class="sr-only">Atelier Kō — hand-carved furniture from the northern woods</h1>
  <section class="relative overflow-hidden bg-base">
    <div class="md:hidden">
      <div class="aspect-[4/3] w-full">
        <Image
          src={heroImg}
          alt="Hand-carved sculptural walnut lounge chair in a sunlit atelier"
          width={1600}
          height={1280}
          format="webp"
          loading="eager"
          decoding="sync"
          class="h-full w-full object-cover object-right"
        />
      </div>
      <div class="space-y-6 px-6 py-12">
        <p class="flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
          <span class="inline-block h-px w-8 bg-ink/40"></span>
          Småland, Sweden · Est. 2018
        </p>
        <p class="text-balance font-serif text-4xl leading-[0.95]">
          Hand-carved pieces
          <br />
          <span class="italic text-accent">from the northern woods.</span>
        </p>
        <p class="max-w-[48ch] text-pretty leading-relaxed text-faded">
          A small, slow catalogue of seating, tables and storage — solid oak, ash and walnut, shaped by hand
          and built to outlast the room they were made for.
        </p>
        <div class="flex flex-col items-start gap-4 pt-2 sm:flex-row sm:items-center">
          <a
            href="/catalog"
            class="group inline-flex items-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
          >
            Browse the catalogue
            <span aria-hidden class="transition-transform group-hover:translate-x-1">→</span>
          </a>
          <a href="/about" class="text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink">
            Our workshop →
          </a>
        </div>
      </div>
    </div>

    <div class="relative hidden h-[88vh] max-h-[920px] min-h-[640px] w-full md:block">
      <Image
        src={heroImg}
        alt="Hand-carved sculptural walnut lounge chair in a sunlit atelier"
        width={1600}
        height={1280}
        format="webp"
        loading="eager"
        decoding="sync"
        class="absolute inset-0 h-full w-full object-cover object-right"
      />
      <div
        aria-hidden="true"
        class="absolute inset-0"
        style="background: linear-gradient(90deg, var(--color-base) 0%, var(--color-base) 30%, color-mix(in oklab, var(--color-base) 55%, transparent) 45%, color-mix(in oklab, var(--color-base) 5%, transparent) 65%, transparent 80%)"
      >
      </div>
      <div
        aria-hidden="true"
        class="absolute inset-x-0 bottom-0 h-40"
        style="background: linear-gradient(180deg, transparent, var(--color-base))"
      >
      </div>
      <div class="relative mx-auto flex h-full max-w-screen-xl items-center px-6">
        <div class="max-w-[480px] space-y-8">
          <p class="flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
            <span class="inline-block h-px w-8 bg-ink/40"></span>
            Småland, Sweden · Est. 2018
          </p>
          <p class="text-balance font-serif text-5xl leading-[0.95] lg:text-6xl">
            Hand-carved pieces
            <br />
            <span class="italic text-accent">from the northern woods.</span>
          </p>
          <p class="max-w-[48ch] text-pretty leading-relaxed text-faded md:text-lg">
            A small, slow catalogue of seating, tables and storage — solid oak, ash and walnut, shaped by hand
            and built to outlast the room they were made for.
          </p>
          <div class="flex items-center gap-6 pt-2">
            <a
              href="/catalog"
              class="group inline-flex items-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
            >
              Browse the catalogue
              <span aria-hidden class="transition-transform group-hover:translate-x-1">→</span>
            </a>
            <a href="/about" class="text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink">
              Our workshop →
            </a>
          </div>
        </div>
      </div>
      <div class="absolute bottom-10 right-10 hidden flex-col items-end gap-1 text-[10px] uppercase tracking-[0.3em] text-ink/70 md:flex">
        <span>No. 04 — Arvid Lounge</span>
        <span class="text-faded">Solid Walnut · 2025</span>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-screen-xl px-6 pt-24 md:pt-32">
    <div class="mb-12 flex items-end justify-between gap-6 border-t border-line pt-10">
      <div>
        <p class="mb-4 text-[11px] uppercase tracking-[0.3em] text-faded">Currently in the workshop</p>
        <h2 class="max-w-[20ch] text-balance font-serif text-3xl md:text-5xl">
          A few pieces, <span class="italic text-accent">close to ready.</span>
        </h2>
      </div>
      <a
        href="/catalog"
        class="hidden items-center gap-2 whitespace-nowrap text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink md:inline-flex"
      >
        View all
        <span aria-hidden>→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-3">
      {featured.map((product, index) => <ProductCard product={product} eager={index === 0} />)}
    </div>

    <div class="mt-10 flex justify-center md:hidden">
      <a href="/catalog" class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink">
        View the full catalogue →
      </a>
    </div>
  </section>

  <section class="mt-32 md:mt-48">
    <div class="mx-auto max-w-screen-2xl px-6">
      <div class="grid items-center gap-10 md:grid-cols-12 md:gap-16">
        <div class="md:col-span-7 lg:col-span-8">
          <a
            href={`/products/${solo.slug}`}
            class="group block aspect-[5/4] overflow-hidden rounded-[min(1vw,16px)] bg-paper md:aspect-[16/11]"
          >
            <Image
              src={solo.images[0]}
              alt={`${solo.name} — ${solo.shortDescription}`}
              width={1600}
              height={1100}
              loading="lazy"
              format="webp"
              class="h-full w-full object-cover transition-transform duration-[1400ms] ease-out group-hover:scale-[1.02]"
            />
          </a>
        </div>
        <div class="space-y-6 md:col-span-5 lg:col-span-4">
          <p class="flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
            <span class="inline-block h-px w-8 bg-ink/40"></span>
            The Monolith
          </p>
          <h2 class="text-balance font-serif text-4xl leading-[1.02] md:text-5xl">
            One plank. <span class="italic text-accent">No hardware.</span>
          </h2>
          <p class="text-pretty leading-relaxed text-faded">{solo.description}</p>
          <dl class="grid grid-cols-2 gap-x-6 gap-y-3 border-t border-line pt-2 text-xs">
            <dt class="pt-3 uppercase tracking-[0.2em] text-faded">Dimensions</dt>
            <dd class="pt-3">{solo.dimensions}</dd>
            <dt class="uppercase tracking-[0.2em] text-faded">Finish</dt>
            <dd>{solo.finish}</dd>
            <dt class="uppercase tracking-[0.2em] text-faded">Lead time</dt>
            <dd>{solo.leadTime}</dd>
            <dt class="uppercase tracking-[0.2em] text-faded">From</dt>
            <dd class="tabular-nums">{formatPrice(solo.price)}</dd>
          </dl>
          <a
            href={`/products/${solo.slug}`}
            class="inline-flex items-center gap-3 rounded-full bg-ink px-6 py-3.5 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
          >
            See the piece →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto mt-32 max-w-screen-xl px-6 md:mt-48">
    <div class="border-t border-line pt-12">
      <p class="mb-4 text-[11px] uppercase tracking-[0.3em] text-faded">Three woods, no more</p>
      <h2 class="mb-12 max-w-[22ch] text-balance font-serif text-3xl md:text-5xl">
        We've spent years learning <span class="italic text-accent">three timbers</span>.
      </h2>
      <div class="grid gap-x-8 gap-y-10 md:grid-cols-3">
        {
          [
            {
              name: "European Oak",
              tag: "Quiet · structural",
              copy: "A single grade of slow-grown oak from managed forests in southern Sweden. Quarter-sawn for stability.",
            },
            {
              name: "Curved Ash",
              tag: "Resilient · sprung",
              copy: "A small reserve from the south coast, steam-bent over custom forms. Used only where the curve earns it.",
            },
            {
              name: "American Walnut",
              tag: "Warm · figured",
              copy: "Bought in single planks from a family mill in Pennsylvania. The grain decides the piece, not the other way around.",
            },
          ].map((material) => (
            <div class="space-y-3 pt-2">
              <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{material.tag}</p>
              <h3 class="font-serif text-2xl">{material.name}</h3>
              <p class="text-sm leading-relaxed text-faded">{material.copy}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto mt-32 max-w-screen-xl px-6 md:mt-48">
    <div class="border-t border-line pt-12">
      <div class="mx-auto max-w-xl space-y-6 text-center">
        <p class="text-[11px] uppercase tracking-[0.3em] text-faded">Stay informed</p>
        <h2 class="text-balance font-serif text-3xl md:text-5xl">
          New pieces, <span class="italic text-accent">one email at a time.</span>
        </h2>
        <p class="mx-auto max-w-[52ch] text-sm leading-relaxed text-faded">
          We make slowly. When something is ready — or when we open the books for new commissions — we send a short note.
        </p>

        <form class="space-y-3 pt-4 text-left" data-newsletter-form>
          <div class="flex flex-col gap-3 sm:flex-row">
            <label class="sr-only" for="first-name">First name</label>
            <input
              id="first-name"
              name="firstName"
              type="text"
              required
              maxlength="80"
              placeholder="First name"
              class="flex-1 rounded-full bg-paper px-5 py-4 text-sm text-ink placeholder:text-faded/60 focus:outline-none focus:ring-1 focus:ring-ink disabled:opacity-50"
            />
            <label class="sr-only" for="email">Email address</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="your@email.com"
              class="flex-1 rounded-full bg-paper px-5 py-4 text-sm text-ink placeholder:text-faded/60 focus:outline-none focus:ring-1 focus:ring-ink disabled:opacity-50"
            />
          </div>
          <button
            type="submit"
            class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent disabled:opacity-50"
            data-newsletter-button
          >
            Notify me
          </button>
          <p class="hidden pt-2 text-center text-sm text-accent" data-newsletter-success aria-live="polite">
            You're on the list. We'll be in touch.
          </p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Atelier Kō",
    url: Astro.site?.href ?? "https://atelier-ko-topaz.vercel.app/",
    slogan: "Furniture, made by hand",
    address: {
      "@type": "PostalAddress",
      addressRegion: "Småland",
      addressCountry: "SE",
    },
  })}></script>

  <script is:inline>
    const form = document.querySelector("[data-newsletter-form]");
    if (form) {
      const button = form.querySelector("[data-newsletter-button]");
      const success = form.querySelector("[data-newsletter-success]");

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        button.disabled = true;
        button.textContent = "Saving...";
        window.setTimeout(() => {
          form.reset();
          button.disabled = false;
          button.textContent = "Notify me";
          success.classList.remove("hidden");
        }, 450);
      });
    }
  </script>
  </main>
</BaseLayout>
