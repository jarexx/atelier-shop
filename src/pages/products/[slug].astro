---
import { Image } from "astro:assets";
import ProductCard from "@/components/ProductCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatPrice, getProducts, getRelated } from "@/data/products.js";

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product, related: getRelated(products, product.slug) },
  }));
}

const { product, related } = Astro.props;
const productUrl = new URL(`/products/${product.slug}`, Astro.site ?? Astro.url.origin).href;
---

<BaseLayout
  title={`${product.name} — Jarek Sikorski art`}
  description={product.description.slice(0, 155)}
  image={product.images[0]}
>
  <main id="main-content">
  <div class="mx-auto max-w-screen-xl px-6 pt-8">
    <nav class="flex gap-2 text-xs uppercase tracking-widest text-faded" aria-label="Breadcrumb">
      <a href="/catalog" class="hover:text-ink">Catalogue</a>
      <span aria-hidden="true">/</span>
      <span class="text-ink" aria-current="page">{product.name}</span>
    </nav>
  </div>

  <div class="mx-auto max-w-screen-xl px-6 py-12">
    <section class="grid grid-cols-1 items-start gap-16 lg:grid-cols-12">
      <div class="space-y-6 lg:col-span-7" data-product-gallery>
        <div class="relative aspect-[4/5] overflow-hidden rounded-[min(1vw,12px)] bg-paper">
          {
            product.images.map((image, index) => (
              <div class:list={["absolute inset-0", index !== 0 && "hidden"]} data-gallery-panel={index}>
                <Image
                  src={image}
                  alt={`${product.name} — view ${index + 1}`}
                  width={1440}
                  height={1800}
                  format="webp"
                  loading={index === 0 ? "eager" : "lazy"}
                  class="atelier-fade-in h-full w-full object-cover"
                />
              </div>
            ))
          }
        </div>
        <div class="grid grid-cols-3 gap-4">
          {
            product.images.map((image, index) => (
              <button
                type="button"
                class:list={[
                  "aspect-square overflow-hidden rounded-[min(1vw,12px)] bg-paper ring-1 transition-all",
                  index === 0 ? "ring-ink" : "ring-line hover:ring-ink/40",
                ]}
                data-gallery-thumb={index}
                aria-label={`Show view ${index + 1}`}
                aria-pressed={index === 0 ? "true" : "false"}
              >
                <Image src={image} alt="" width={360} height={360} format="webp" loading="lazy" class="h-full w-full object-cover" />
              </button>
            ))
          }
        </div>
      </div>

      <div class="space-y-12 lg:sticky lg:top-24 lg:col-span-5">
        <div class="space-y-4">
          <div class="text-xs uppercase tracking-widest text-faded">{product.collection}</div>
          <h1 class="text-balance font-serif text-4xl leading-tight md:text-5xl">{product.name}</h1>
          <p class="font-serif text-2xl">{formatPrice(product.price)}</p>
        </div>

        <div class="space-y-6">
          <p class="max-w-[44ch] text-pretty leading-relaxed text-faded">{product.description}</p>
          <dl class="space-y-3">
            <div class="flex justify-between border-b border-line py-2 text-sm">
              <dt class="text-faded">Material</dt>
              <dd>{product.material}</dd>
            </div>
            <div class="flex justify-between border-b border-line py-2 text-sm">
              <dt class="text-faded">Dimensions</dt>
              <dd>{product.dimensions}</dd>
            </div>
            <div class="flex justify-between border-b border-line py-2 text-sm">
              <dt class="text-faded">Finish</dt>
              <dd>{product.finish}</dd>
            </div>
            <div class="flex justify-between border-b border-line py-2 text-sm">
              <dt class="text-faded">Lead Time</dt>
              <dd>{product.leadTime}</dd>
            </div>
          </dl>
        </div>

        <button
          type="button"
          data-add-to-cart={product.slug}
          class="w-full rounded-full bg-ink py-4 text-sm font-medium text-[var(--color-base)] ring-1 ring-ink transition-all hover:bg-accent hover:ring-accent active:scale-[0.98]"
        >
          Add to Collection
        </button>

        <p class="text-[11px] uppercase tracking-widest text-faded">
          Free white-glove delivery in EU · Worldwide on request
        </p>
      </div>
    </section>

    <section class="mt-40 space-y-12 border-t border-line pt-16">
      <div class="flex items-end justify-between gap-6">
        <h2 class="font-serif text-3xl md:text-4xl">Pieces that sit well together</h2>
        <a href="/catalog" class="text-xs uppercase tracking-widest underline underline-offset-4 hover:text-accent">
          View all
        </a>
      </div>
      <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-3">
        {related.map((item) => <ProductCard product={item} />)}
      </div>
    </section>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: product.name,
    description: product.description,
    image: product.images.map((image) => new URL(image.src, Astro.url.origin).href),
    brand: {
      "@type": "Brand",
      name: "Jarek Sikorski art",
    },
    material: product.material,
    url: productUrl,
    offers: {
      "@type": "Offer",
      priceCurrency: "USD",
      price: product.price,
      availability: "https://schema.org/PreOrder",
      url: productUrl,
    },
  })}></script>

  <script is:inline>
    const gallery = document.querySelector("[data-product-gallery]");
    if (gallery) {
      const panels = Array.from(gallery.querySelectorAll("[data-gallery-panel]"));
      const thumbs = Array.from(gallery.querySelectorAll("[data-gallery-thumb]"));

      thumbs.forEach((thumb) => {
        thumb.addEventListener("click", () => {
          const active = thumb.dataset.galleryThumb;
          panels.forEach((panel) => panel.classList.toggle("hidden", panel.dataset.galleryPanel !== active));
          thumbs.forEach((button) => {
            const selected = button.dataset.galleryThumb === active;
            button.classList.toggle("ring-ink", selected);
            button.classList.toggle("ring-line", !selected);
            button.setAttribute("aria-pressed", selected ? "true" : "false");
          });
        });
      });
    }

    const addButton = document.querySelector("[data-add-to-cart]");
    if (addButton) {
      const originalText = addButton.textContent;
      let timer;
      addButton.addEventListener("click", () => {
        window.AtelierCart.add(addButton.dataset.addToCart, 1);
        addButton.textContent = "Added to your archive →";
        window.clearTimeout(timer);
        timer = window.setTimeout(() => {
          addButton.textContent = originalText;
        }, 1800);
      });
    }
  </script>
  </main>
</BaseLayout>
