---
const year = new Date().getFullYear();
---

<footer id="studio" class="mt-32 border-t border-line py-24">
  <div class="mx-auto grid max-w-screen-xl grid-cols-1 gap-12 px-6 md:grid-cols-3">
    <div class="space-y-4">
      <div class="font-serif text-lg italic tracking-tight">Jarek Sikorski art</div>
      <p class="max-w-[30ch] text-sm leading-relaxed text-faded">
        Sustainable furniture designed and made by hand in Småland, Sweden.
      </p>
    </div>
    <div class="space-y-4">
      <h2 class="text-xs font-medium uppercase tracking-widest">Inquiries</h2>
      <ul class="space-y-2 text-sm">
        <li><a href="/about#studio" class="text-faded transition-colors hover:text-ink">Custom Orders</a></li>
        <li><a href="/about#studio" class="text-faded transition-colors hover:text-ink">Trade Portal</a></li>
        <li><a href="/about#studio" class="text-faded transition-colors hover:text-ink">Studio Visits</a></li>
      </ul>
    </div>
    <div class="space-y-4">
      <h2 class="text-xs font-medium uppercase tracking-widest">Follow</h2>
      <ul class="space-y-2 text-sm">
        <li><a href="https://www.instagram.com/" class="text-faded transition-colors hover:text-ink">Instagram</a></li>
        <li><a href="/about" class="text-faded transition-colors hover:text-ink">Journal</a></li>
      </ul>
    </div>
  </div>
  <div class="mx-auto mt-16 max-w-screen-xl px-6 text-[10px] uppercase tracking-[0.2em] text-faded">
    © {year} Jarek Sikorski art — All pieces made to order.
  </div>
</footer>
